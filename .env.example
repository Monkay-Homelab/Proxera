# Proxera - Environment Configuration
# Copy this file to .env and update the values.
#
# Most settings can also be configured in the Admin panel after first setup.
# Values set in Admin > Settings override these defaults.
#
# Docker-specific vars (PROXERA_DOCKER, DB_HOST override, NGINX_RELOAD_CMD,
# NGINX_TEST_CMD, DOCKER_GID) are set in docker-compose.yml — not here.

# ==============================================================================
# DATABASE
# ==============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=proxera
DB_USER=proxera
DB_PASSWORD=CHANGE_ME
DB_SSL_MODE=disable

# ==============================================================================
# API
# ==============================================================================
API_HOST=0.0.0.0
API_PORT=8080

# Comma-separated list of allowed origins, or * to allow all (default).
# Set specific origins if the panel runs on a different host/port.
#CORS_ORIGINS=*

# Secrets — generate secure values for production:
#   openssl rand -hex 32
JWT_SECRET=CHANGE_ME
ENCRYPTION_KEY=CHANGE_ME

# ==============================================================================
# OPTIONAL OVERRIDES
# ==============================================================================
# Nginx paths are auto-detected. Only set these if you have a non-standard setup.
#NGINX_CONFIG_PATH=/etc/nginx/conf.d
#NGINX_ENABLED_PATH=/etc/nginx/conf.d

# ==============================================================================
# CONFIGURABLE IN ADMIN PANEL
# ==============================================================================
# The settings below can be set here as defaults, but are also configurable
# at runtime via Admin > Settings (no restart needed). Panel values take priority.

# Public URLs — used for email links, install scripts, and agent WebSocket.
# Leave empty for Docker AIO (same-origin).
#PUBLIC_API_URL=https://proxera.example.com
#PUBLIC_WS_URL=wss://proxera.example.com/ws
#PUBLIC_SITE_URL=https://proxera.example.com

# SMTP — for email notifications and verification.
#SMTP_HOST=smtp.example.com
#SMTP_PORT=465
#SMTP_USER=
#SMTP_PASSWORD=
#SMTP_FROM_EMAIL=noreply@example.com

# Require email verification for new accounts.
#ENABLE_EMAIL_VERIFICATION=false

# Use Let's Encrypt staging for testing (certs won't be trusted by browsers).
#ACME_STAGING=false
